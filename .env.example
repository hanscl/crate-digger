# =============================================================================
# Crate Digger — environment variables
# Copy to .env and fill in. Required keys are marked REQUIRED.
# =============================================================================

# REQUIRED. Postgres connection string.
# Local docker-compose default below. For Neon/Supabase/RDS/Fly Postgres, swap
# the URL — the app does not care which provider it is.
DATABASE_URL=postgres://cratedigger:cratedigger@localhost:5432/cratedigger

# Postgres bootstrap credentials, used only by the local docker-compose Postgres
# service (ignored when DATABASE_URL points to a managed provider). Defaults are
# fine for local dev — the port is bound to 127.0.0.1 only. For shared hosts
# (e.g. a VPS), generate a strong password (`openssl rand -hex 24`) and update
# DATABASE_URL above to match.
POSTGRES_USER=cratedigger
POSTGRES_PASSWORD=cratedigger
POSTGRES_DB=cratedigger

# REQUIRED. Shared secret for the single-user admin dashboard. Anything random,
# e.g. `openssl rand -hex 32`. Do not ship a default — the app refuses to boot if unset.
ADMIN_PASSPHRASE=

# OPTIONAL. Anthropic API key. Powers bucket auto-naming, "why surfaced"
# explanations, and cold-start playlist parsing. The app boots without it;
# those features no-op or fall back to deterministic placeholders.
ANTHROPIC_API_KEY=

# OPTIONAL. Spotify app credentials. Required only if you want Spotify ingest
# (search + metadata + genres) — the source adapter is skipped when these are
# unset. Create an app at https://developer.spotify.com/dashboard
#
# Spotify reality check (see docs/SOURCES.md):
#  - Audio features do NOT come from Spotify anymore. `/audio-features` was
#    retired for apps registered after 2024-11-27 — Crate Digger gets them
#    from ReccoBeats instead (no key, see below).
#  - As of 2026-02-06 every Dev Mode app requires the OWNER to hold Spotify
#    Premium. There is no localhost / single-user exemption.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Redirect URI used during the OAuth flow on the Setup screen.
# MUST use the IPv4 loopback `127.0.0.1` — Spotify no longer accepts
# `localhost` as a redirect host. Whatever you put here must match the
# Redirect URI registered in the Spotify Developer Dashboard exactly.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/auth/spotify/callback

# ReccoBeats (https://reccobeats.com) supplies audio features by Spotify
# track id. It needs NO API key — there is deliberately no env var for it.
# Toggle it on the Sources screen; rate limiting is built in (see
# src/lib/enrichment/rate-limit.ts).

# OPTIONAL. Last.fm API key. Drives both the Last.fm ingest adapter AND
# the artist-tag genre enricher (the main genre signal). Free key:
# https://www.last.fm/api/account/create
LASTFM_API_KEY=

# OPTIONAL. MusicBrainz contact email — folded into the User-Agent header
# per MB's API policy. Enables the MusicBrainz recording-genre enricher
# (an additional genre source layered on top of Last.fm artist tags).
# Recovers per-track signal that Last.fm artist-only collapses. Free, no
# API key needed — the email is the identifier. Leave empty to skip.
MUSICBRAINZ_CONTACT_EMAIL=

# OPTIONAL. Discogs consumer key/secret pair. Enables the Discogs genre +
# style enricher (master-first lookup, falls back to release). Both must
# be set; either empty disables the source. Free credentials:
# https://www.discogs.com/settings/developers
#
# Genre signal degrades gracefully — Last.fm artist tags alone produce a
# working but coarser vector; adding MusicBrainz recovers per-track signal;
# adding Discogs adds curated style sub-genres on top.
DISCOGS_KEY=
DISCOGS_SECRET=

# OPTIONAL. Viberate is a paid trend source. The system runs fully on
# Spotify + Last.fm with reduced trend signal when this is unset.
VIBERATE_API_KEY=

# =============================================================================
# TikTok-velocity source (LAB-19). Adds TikTok trending songs as a discovery
# signal. Paid + optional: with no provider set, the `tiktok` adapter is
# skipped and the system runs on Spotify + Last.fm. Two providers are
# supported; the first one configured wins (Chartmetric preferred on cost).
# Enable the source on the Sources screen once credentials are set.
# =============================================================================

# RECOMMENDED provider — Chartmetric (https://chartmetric.com). Usage-based
# (~$0.01/credit, $5 free trial), so cheap for a single-user install. This is
# the long-lived REFRESH token, exchanged in-app for a short-lived bearer.
# Get one under API Access → "Get access". Optionally set the chart territory
# (ISO Alpha-2; default US).
CHARTMETRIC_REFRESH_TOKEN=
# CHARTMETRIC_TIKTOK_COUNTRY=US

# ALTERNATIVE provider — Soundcharts (https://soundcharts.com). Live-verified
# but a $250/mo minimum, so usually not worth it for a personal install. BOTH
# the app id and api key are required. The public sandbox pair
# `soundcharts` / `soundcharts` serves fixed demo data (no TikTok breakout
# charts) for development.
SOUNDCHARTS_APP_ID=
SOUNDCHARTS_API_KEY=
# Which TikTok chart to pull (Soundcharts slug). Defaults to the US "Breakout"
# velocity chart. Other examples: tiktok-breakout-gb, tiktok-breakout-de.
# SOUNDCHARTS_TIKTOK_CHART_SLUG=tiktok-breakout-us

# OPTIONAL. HTTP port the server listens on (default 3000).
PORT=3000

# OPTIONAL. Runtime mode: development | production | test. Defaults to
# "development" outside Docker; the compose `app` service overrides to
# "production". Set this to "production" for any non-Docker deployment behind
# TLS — the auth cookie's Secure flag is gated on NODE_ENV=production.
# NODE_ENV=development

# OPTIONAL. Set to "1" or "true" to disable the in-process node-cron schedule.
# Manual triggers (Console "Run now") still work; only the timed pipeline +
# keepalive heartbeats are skipped. Useful for tests and reduced-env deploys.
# CRON_DISABLED=
