# =============================================================================
# Crate Digger — environment variables
# Copy to .env and fill in. Required keys are marked REQUIRED.
# =============================================================================

# REQUIRED. Postgres connection string.
# Local docker-compose default below. For Neon/Supabase/RDS/Fly Postgres, swap
# the URL — the app does not care which provider it is.
DATABASE_URL=postgres://cratedigger:cratedigger@localhost:5432/cratedigger

# Postgres bootstrap credentials, used only by the local docker-compose Postgres
# service (ignored when DATABASE_URL points to a managed provider). Defaults are
# fine for local dev — the port is bound to 127.0.0.1 only. For shared hosts
# (e.g. a VPS), generate a strong password (`openssl rand -hex 24`) and update
# DATABASE_URL above to match.
POSTGRES_USER=cratedigger
POSTGRES_PASSWORD=cratedigger
POSTGRES_DB=cratedigger

# REQUIRED. Shared secret for the single-user admin dashboard. Anything random,
# e.g. `openssl rand -hex 32`. Do not ship a default — the app refuses to boot if unset.
ADMIN_PASSPHRASE=

# OPTIONAL. Anthropic API key. Powers bucket auto-naming, "why surfaced"
# explanations, and cold-start playlist parsing. The app boots without it;
# those features no-op or fall back to deterministic placeholders.
ANTHROPIC_API_KEY=

# OPTIONAL. Spotify app credentials. Required only if you want Spotify ingest
# + audio-feature enrichment — the source adapter is skipped when these are
# unset. Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Redirect URI used during the OAuth flow on the Setup screen.
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/auth/spotify/callback

# OPTIONAL. Last.fm API key. Required only if you want Last.fm ingest — the
# adapter is skipped when unset. Free key: https://www.last.fm/api/account/create
LASTFM_API_KEY=

# OPTIONAL. Viberate is a paid trend source. The system runs fully on
# Spotify + Last.fm with reduced trend signal when this is unset.
VIBERATE_API_KEY=

# OPTIONAL. HTTP port the server listens on (default 3000).
PORT=3000

# OPTIONAL. Runtime mode: development | production | test. Defaults to
# "development" outside Docker; the compose `app` service overrides to
# "production". Set this to "production" for any non-Docker deployment behind
# TLS — the auth cookie's Secure flag is gated on NODE_ENV=production.
# NODE_ENV=development

# OPTIONAL. Set to "1" or "true" to disable the in-process node-cron schedule.
# Manual triggers (Console "Run now") still work; only the timed pipeline +
# keepalive heartbeats are skipped. Useful for tests and reduced-env deploys.
# CRON_DISABLED=
