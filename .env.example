# =============================================================================
# Crate Digger — environment variables
# Copy to .env and fill in. Required keys are marked REQUIRED.
# =============================================================================

# REQUIRED. Postgres connection string.
# Local docker-compose default below. For Neon/Supabase/RDS/Fly Postgres, swap
# the URL — the app does not care which provider it is.
DATABASE_URL=postgres://cratedigger:cratedigger@localhost:5432/cratedigger

# REQUIRED. Shared secret for the single-user admin dashboard. Anything random,
# e.g. `openssl rand -hex 32`. Do not ship a default — the app refuses to boot if unset.
ADMIN_PASSPHRASE=

# REQUIRED. Anthropic API key for bucket auto-naming, "why surfaced" explanations,
# and (optional) cold-start playlist parsing.
ANTHROPIC_API_KEY=

# REQUIRED for Spotify ingest + audio-feature enrichment.
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Redirect URI used during the OAuth flow on the Setup screen.
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/auth/spotify/callback

# REQUIRED for Last.fm ingest. Free key: https://www.last.fm/api/account/create
LASTFM_API_KEY=

# OPTIONAL. Viberate is a paid trend source. The system runs fully on
# Spotify + Last.fm with reduced trend signal when this is unset.
VIBERATE_API_KEY=

# OPTIONAL. HTTP port the server listens on (default 3000).
PORT=3000
